{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["message", "status"],
  "properties": {
    "message": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["success"]
    }
  },
  "additionalProperties": false
}

